<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xtax.mapper.processMapper">
    <!--  条件分页查询工序信息  -->
    <resultMap id="processPage" type="com.xtax.entity.Processes">
        <!-- 主表字段 -->
        <id property="id" column="id"/>
        <result property="processName" column="process_name"/>
        <result property="plannedWorkingHours" column="planned_working_hours"/>
        <result property="description" column="description"/>
        <result property="qualityControlPoint" column="quality_control_point"/>

        <!-- 输入 BOM 集合 -->
        <collection property="inputBomId"
                    ofType="java.lang.Integer"
                    column="id"
                    select="getInputBoms"/>

        <!-- 输出 BOM 集合 -->
        <collection property="outputBomId"
                    ofType="java.lang.Integer"
                    column="id"
                    select="getOutputBoms"/>

        <!-- 工步集合 -->
        <collection property="workStepId"
                    ofType="java.lang.Integer"
                    column="id"
                    select="getWorkSteps"/>
    </resultMap>

    <!-- 主查询：仅查 processes 主表，最干净最安全 -->
    <select id="getProcess" resultMap="processPage">
        SELECT
        p.id,
        p.process_name,
        p.planned_working_hours,
        p.description,
        p.quality_control_point
        FROM processes p
        <where>
            <if test="processName != null and processName != ''">
                AND p.process_name LIKE CONCAT('%', #{processName}, '%')
            </if>

            <!-- 输入 BOM 过滤 -->
            <if test="inputBom != null and inputBom.size() > 0 ">
                AND EXISTS (
                SELECT 1 FROM input i
                WHERE i.process_id = p.id AND i.input in
                <foreach item="bom" collection="inputBom" separator="," open="(" close=")">
                    #{bom}
                </foreach>
                )
            </if>

            <!-- 输出 BOM 过滤 -->
            <if test="outputBom != null and outputBom.size() > 0 ">
                AND EXISTS (
                SELECT 1 FROM output o
                WHERE o.process_id = p.id AND o.output in
                <foreach item="bom" collection="outputBom" separator="," open="(" close=")">
                    #{bom}
                </foreach>
                )
            </if>
        </where>
    </select>

    <!-- 子查询：输入 BOM 列表 -->
    <select id="getInputBoms" resultType="java.lang.Integer">
        SELECT input
        FROM input
        WHERE process_id = #{id}
    </select>

    <!-- 子查询：输出 BOM 列表 -->
    <select id="getOutputBoms" resultType="java.lang.Integer">
        SELECT output
        FROM output
        WHERE process_id = #{id}
    </select>

    <!-- 子查询：工步 ID 列表 -->
    <select id="getWorkSteps" resultType="java.lang.Integer">
        SELECT work_step_id
        FROM process_steps
        WHERE process_id = #{id}
    </select>

    <insert id="addProcess"  useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        INSERT INTO processes(process_name, planned_working_hours, description, quality_control_point)
        VALUES (#{processName}, #{plannedWorkingHours}, #{description}, #{qualityControlPoint})
    </insert>

    <insert id="insertInputBom">
        INSERT INTO input (process_id, input)
        VALUES
        <foreach collection="inputBomId" item="bom" separator=",">
            (#{processId}, #{bom})
        </foreach>
    </insert>

    <insert id="insertOutputBom">
        INSERT INTO output (process_id, output)
        VALUES
        <foreach collection="outputBomId" item="bom" separator=",">
            (#{processId}, #{bom})
        </foreach>
    </insert>

    <insert id="insertWorkStep">
        INSERT INTO process_steps (process_id, work_step_id)
        VALUES
        <foreach collection="workStepId" item="step" separator=",">
            (#{processId}, #{step})
        </foreach>
    </insert>

    <delete id="deleteProcess">
        delete from processes where id in
          <foreach item="id" collection="ids" separator="," open="(" close=")">
              #{id}
          </foreach>
    </delete>

    <delete id="deleteInputBom">
        delete from input where process_id = #{processId}
    </delete>

    <delete id="deleteOutputBom">
        delete from output where process_id = #{processId}
    </delete>

    <delete id="deleteWorkStep">
        delete from process_steps where process_id = #{processId}
    </delete>

    <update id="updateProcess">
        update processes set process_name = #{processName}, planned_working_hours = #{plannedWorkingHours}, description = #{description}, quality_control_point = #{qualityControlPoint} where id = #{id}
    </update>
</mapper>