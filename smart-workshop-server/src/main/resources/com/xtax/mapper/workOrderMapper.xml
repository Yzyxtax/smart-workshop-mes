<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xtax.mapper.workOrderMapper">
    <!--
        按状态感知规则更新工单（动态 SQL）
        调用方需在 Service 层确保只传入当前状态下允许修改的字段
    -->
    <update id="updateWorkOrder">
        update work_order
        <set>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="processId != null">process_id = #{processId},</if>
            <if test="isCritical != null">is_critical = #{isCritical},</if>
            <if test="plannedQuantity != null">planned_quantity = #{plannedQuantity},</if>
            <if test="actualQuantity != null">actual_quantity = #{actualQuantity},</if>
            <if test="scrapQuantity != null">scrap_quantity = #{scrapQuantity},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = now()
        </set>
        where work_order_no = #{workOrderNo}
    </update>
</mapper>
