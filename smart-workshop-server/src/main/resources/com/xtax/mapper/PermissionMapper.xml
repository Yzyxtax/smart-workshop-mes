<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xtax.mapper.PermissionMapper">
    <!-- 查询所有权限，可按模块筛选 -->
    <select id="getAllPermission" resultType="com.xtax.entity.Permission">
        select * from permission
        <where>
            <if test="module != null and module != ''">
                module = #{module}
            </if>
        </where>
        order by module, id
    </select>

    <!-- 根据ID查询权限 -->
    <select id="getPermissionById" resultType="com.xtax.entity.Permission">
        select * from permission where id = #{id}
    </select>

    <!-- 根据权限编码查询权限 -->
    <select id="getPermissionByCode" resultType="com.xtax.entity.Permission">
        select * from permission where permission_code = #{permissionCode}
    </select>

    <!-- 查询用户的所有权限编码 -->
    <select id="getUserPermissionCodes" resultType="string">
        SELECT DISTINCT p.permission_code
        FROM permission p
        INNER JOIN role_permission rp ON p.id = rp.permission_id
        INNER JOIN user_role ur ON rp.role_id = ur.role_id
        WHERE ur.user_id = #{userId}
    </select>
</mapper>